<?xml version="1.0"?>
<sdf version="1.7">
  <model name="test_robot">
    <link name="base_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.01</iyy><iyz>0</iyz><izz>0.01</izz>
        </inertia>
      </inertial>
      <visual name="visual_0">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.2 0.2 0.1</size></box>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
        </material>
      </visual>
      <collision name="collision_0">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.2 0.2 0.1</size></box>
        </geometry>
      </collision>
    </link>

    <link name="link1">
      <inertial>
        <pose>0 0 0.1 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="visual_0">
        <pose>0 0 0.1 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.02</radius><length>0.2</length></cylinder>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
        </material>
      </visual>
    </link>

    <link name="link2">
      <inertial>
        <pose>0 0 0.075 0 0 0</pose>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.0005</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0005</iyy><iyz>0</iyz><izz>0.0005</izz>
        </inertia>
      </inertial>
      <visual name="visual_0">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry>
          <sphere><radius>0.03</radius></sphere>
        </geometry>
      </visual>
    </link>

    <link name="fixed_part">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="visual_0">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.05 0.05 0.02</size></box>
        </geometry>
      </visual>
    </link>

    <joint name="joint1" type="revolute">
      <parent>base_link</parent>
      <child>link1</child>
      <pose>0 0 0.05 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>1.57</upper>
          <effort>10</effort>
          <velocity>5</velocity>
        </limit>
      </axis>
    </joint>

    <joint name="joint2" type="revolute">
      <parent>link1</parent>
      <child>link2</child>
      <pose>0 0 0.2 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-2</lower>
          <upper>2</upper>
          <effort>5</effort>
          <velocity>3</velocity>
        </limit>
      </axis>
    </joint>

    <joint name="fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>fixed_part</child>
      <pose>0.1 0 0 0 0 0</pose>
    </joint>
  </model>
</sdf>
